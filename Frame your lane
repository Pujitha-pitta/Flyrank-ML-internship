        "    df_task[\n",
        "        [\n",
        "            \"content_id\",\n",
        "            \"trend_direction\",\n",
        "            \"trend_pct\",\n",
        "            \"needs_refresh_proxy\"\n",
        "        ]\n",
        "    ].head(10)\n",
        ")"
      ],
